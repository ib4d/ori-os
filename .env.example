# Environment
NODE_ENV=development
PORT=3000
API_PORT=4001

# URLs
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_API_URL=http://localhost:4000
API_URL=http://localhost:4000

# Database
# Note: For Docker Compose, use "postgres" as hostname. For local dev, use "localhost".
DATABASE_URL="postgresql://ori:ori_password@localhost:5432/ori_os?schema=public"

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379

# Authentication (NextAuth.js)
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=super_secret_dev_key_change_me_in_prod

# Object Storage (MinIO/S3)
S3_ENDPOINT=http://localhost:9000
S3_REGION=us-east-1
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin
S3_BUCKET=ori-uploads
S3_PUBLIC_URL=http://localhost:9000/ori-uploads

# Search (MeiliSearch)
MEILISEARCH_HOST=http://localhost:7700
MEILISEARCH_KEY=masterKey

# AI Services (Placeholders)
OPENAI_API_KEY=sk-placeholder
ANTHROPIC_API_KEY=sk-placeholder

# Email (Placeholders)
RESEND_API_KEY=re_placeholder
SENDGRID_API_KEY=SG.placeholder
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=user
SMTP_PASS=pass
FROM_EMAIL=noreply@example.com

# Monitoring (Placeholders)
SENTRY_DSN=

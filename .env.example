# ===========================================
# ORI-OS Environment Configuration
# ===========================================
# Copy this file to .env.local and fill in the values

# Application
NODE_ENV=development
NEXT_PUBLIC_APP_URL=http://localhost:3000
API_URL=http://localhost:4000
NEXT_PUBLIC_API_URL=http://localhost:3000/api

# Database (PostgreSQL)
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/ori_os?schema=public"

# Redis (Queue & Cache)
REDIS_URL="redis://localhost:6379"

# Authentication
NEXTAUTH_SECRET="your-super-secret-key-change-in-production"
NEXTAUTH_URL="http://localhost:3000"

# OAuth Providers (Optional)
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""
GITHUB_CLIENT_ID=""
GITHUB_CLIENT_SECRET=""

# AI Providers (Optional - stub works without these)
OPENAI_API_KEY=""
ANTHROPIC_API_KEY=""

# Email (Optional - local mode works without)
RESEND_API_KEY=""
SMTP_HOST=""
SMTP_PORT=""
SMTP_USER=""
SMTP_PASS=""

# Search (Meilisearch)
MEILISEARCH_HOST="http://localhost:7700"
MEILISEARCH_API_KEY="masterKey"

# Storage (Optional - local filesystem used by default)
S3_ENDPOINT=""
S3_ACCESS_KEY=""
S3_SECRET_KEY=""
S3_BUCKET=""

# Encryption
ENCRYPTION_KEY="32-character-encryption-key-here"

# Sentry (Observability)
SENTRY_DSN=""
SENTRY_ENVIRONMENT="local"
SENTRY_TRACES_SAMPLE_RATE="1.0"
NEXT_PUBLIC_SENTRY_DSN=""

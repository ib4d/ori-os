# ORI-OS Production Environment Template
# Fill these in and rename to .env for production deployment

# --- Core ---
NODE_ENV=production
NEXT_PUBLIC_APP_URL=https://your-domain.com
NEXT_PUBLIC_API_URL=https://api.your-domain.com

# --- Database (PostgreSQL) ---
# When using docker-compose, this should match service name 'postgres'
DATABASE_URL="postgresql://ori:STRONG_PASSWORD@postgres:5432/ori_os?schema=public"

# --- Redis ---
REDIS_URL="redis://redis:6379"

# --- Authentication (NextAuth) ---
# Generate with `openssl rand -base64 32`
NEXTAUTH_SECRET="REPLACE_ME"
NEXTAUTH_URL="https://your-domain.com"
# Turn this OFF in production!
ORI_AUTH_BYPASS="0"

# --- External Integrations ---

# 1. Slack (Webhooks)
SLACK_WEBHOOK_URL="https://hooks.slack.com/services/..."

# 2. OpenAI (Intelligence & Content)
OPENAI_API_KEY="sk-..."

# 3. Resend (Email Outreach)
RESEND_API_KEY="re-..."
FROM_EMAIL="onboarding@resend.dev"

# 4. Search (Meilisearch)
MEILISEARCH_HOST="http://meilisearch:7700"
MEILISEARCH_API_KEY="masterKey"

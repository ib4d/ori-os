# Environment
NODE_ENV=production
PORT=3000
API_PORT=4000

# URLs
# Update these to match your actual domain
NEXT_PUBLIC_APP_URL=https://ori-os.ori-craftlabs.com
NEXT_PUBLIC_API_URL=https://api.ori-os.ori-craftlabs.com
API_URL=https://api.ori-os.ori-craftlabs.com

# Database
# In Docker Compose prod network, hostname is "postgres"
DATABASE_URL="postgresql://ori:ori_password@postgres:5432/ori_os?schema=public"

# Redis
REDIS_HOST=redis
REDIS_PORT=6379

# Authentication (NextAuth.js)
# NEXTAUTH_URL must match your canonical domain
NEXTAUTH_URL=https://ori-os.ori-craftlabs.com
# Generate a secure random string: `openssl rand -base64 32`
NEXTAUTH_SECRET=CHANGE_ME_TO_A_SECURE_RANDOM_STRING

# Object Storage (MinIO)
# Internal Docker URL for API/Worker to talk to MinIO
S3_ENDPOINT=http://minio:9000
S3_REGION=us-east-1
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=CHANGE_ME_MINIO_PASSWORD
S3_BUCKET=ori-uploads
# Public URL for browser to access files (routed via Nginx)
S3_PUBLIC_URL=https://ori-os.ori-craftlabs.com/uploads

# Search (MeiliSearch)
MEILISEARCH_HOST=http://meilisearch:7700
MEILISEARCH_KEY=CHANGE_ME_MASTER_KEY

# AI Services
OPENAI_API_KEY=
ANTHROPIC_API_KEY=

# Email
RESEND_API_KEY=
SENDGRID_API_KEY=
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
FROM_EMAIL=noreply@ori-craftlabs.com

# Security
# Disable auth bypass in production
ORI_AUTH_BYPASS=false

# Monitoring
SENTRY_DSN=

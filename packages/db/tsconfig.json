{
    "compilerOptions": {
        "module": "commonjs",
        "target": "es2019",
        "moduleResolution": "node",
        "outDir": "./dist",
        "rootDir": ".",
        "declaration": true,
        "emitDecoratorMetadata": true,
        "experimentalDecorators": true,
        "esModuleInterop": true,
        "allowSyntheticDefaultImports": true,
        "skipLibCheck": true,
        "strict": false
    },
    "include": [
        "index.ts",
        "nestjs.ts"
    ],
    "exclude": [
        "node_modules",
        "dist"
    ]
}